<!-- views/account/management.ejs -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | CSE Motors
    </title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <h1>
                <%= title %>
            </h1>

            <!-- Display flash messages -->
            <% if (messages.notice) { %>
                <p class="notice">
                    <%= messages.notice %>
                </p>
                <% } %>

                    <!-- Greeting -->
                    <h2>Welcome <%= accountData.account_firstname %>
                    </h2>

                    <!-- Update Account Link - visible to all users -->
                    <p>
                        <a href="/account/update/<%= accountData.account_id %>">Update Account Information</a>
                    </p>

                    <!-- Inventory Management - only for Employee or Admin -->
                    <% if (accountData.account_type==='Employee' || accountData.account_type==='Admin' ) { %>
                        <h3>Inventory Management</h3>
                        <p>
                            <a href="/inv">Manage Inventory</a>
                        </p>
                        <% } %>
        </main>

        <%- include('../partials/footer') %>
</body>

</html><!-- views/account/management.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | CSE Motors</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>
  
  <main>
    <h1><%= title %></h1>
    
    <!-- Display flash messages -->
    <% if (messages.notice) { %>
      <p class="notice"><%= messages.notice %></p>
    <% } %>
    
    <!-- Greeting -->
    <h2>Welcome <%= accountData.account_firstname %></h2>
    
    <!-- Update Account Link - visible to all users -->
    <p>
      <a href="/account/update/<%= accountData.account_id %>">Update Account Information</a>
    </p>
    
    <!-- Inventory Management - only for Employee or Admin -->
    <% if (accountData.account_type === 'Employee' || accountData.account_type === 'Admin') { %>
      <h3>Inventory Management</h3>
      <p>
        <a href="/inv">Manage Inventory</a>
      </p>
    <% } %>
  </main>
  
  <%- include('../partials/footer') %>
</body>
</html>