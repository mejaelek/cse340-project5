<div class="account-container">
    <h1>
        <%= title %>
    </h1>

    <!-- Display flash messages -->
    <% if (messages.notice) { %>
        <p class="notice">
            <%= messages.notice %>
        </p>
        <% } %>

            <!-- Display errors -->
            <% if (errors) { %>
                <ul class="error-list">
                    <% errors.array().forEach(function(error) { %>
                        <li>
                            <%= error.msg %>
                        </li>
                        <% }) %>
                </ul>
                <% } %>

                    <div class="form-section">
                        <h2>Create Your Account</h2>

                        <p class="form-instructions">
                            All fields are required. Please fill out the form completely.
                        </p>

                        <form id="registerForm" action="/account/register" method="post">

                            <label for="account_firstname">First Name:</label>
                            <input type="text" id="account_firstname" name="account_firstname"
                                value="<%= locals.account_firstname %>" required placeholder="Enter your first name"
                                pattern="^[A-Za-z]{2,}$"
                                title="First name must be at least 2 characters and contain only letters">

                            <label for="account_lastname">Last Name:</label>
                            <input type="text" id="account_lastname" name="account_lastname"
                                value="<%= locals.account_lastname %>" required placeholder="Enter your last name"
                                pattern="^[A-Za-z]{2,}$"
                                title="Last name must be at least 2 characters and contain only letters">

                            <label for="account_email">Email Address:</label>
                            <input type="email" id="account_email" name="account_email"
                                value="<%= locals.account_email %>" required placeholder="Enter your email address"
                                pattern="^[^\s@]+@[^\s@]+\.[^\s@]+$" title="Please enter a valid email address">
                            <p class="field-note">We'll never share your email with anyone else.</p>

                            <label for="account_password">Password:</label>
                            <input type="password" id="account_password" name="account_password" required
                                placeholder="Create a strong password"
                                pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{12,}$"
                                title="Password must be at least 12 characters with 1 uppercase, 1 lowercase, 1 number, and 1 special character">
                            <button type="button" id="pswdBtn" onclick="togglePassword()">Show Password</button>

                            <div class="password-requirements">
                                <p><strong>Password Requirements:</strong></p>
                                <ul>
                                    <li>At least 12 characters long</li>
                                    <li>At least 1 uppercase letter (A-Z)</li>
                                    <li>At least 1 lowercase letter (a-z)</li>
                                    <li>At least 1 number (0-9)</li>
                                    <li>At least 1 special character (@$!%*?&)</li>
                                </ul>
                            </div>

                            <button type="submit" class="submit-btn">Register</button>
                        </form>

                        <p class="login-link">
                            Already have an account? <a href="/account/login">Login here</a>
                        </p>
                    </div>
</div>

<script>
    // Password visibility toggle
    function togglePassword() {
        const passwordInput = document.getElementById('account_password');
        const pswdBtn = document.getElementById('pswdBtn');

        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            pswdBtn.textContent = 'Hide Password';
        } else {
            passwordInput.type = 'password';
            pswdBtn.textContent = 'Show Password';
        }
    }
</script>