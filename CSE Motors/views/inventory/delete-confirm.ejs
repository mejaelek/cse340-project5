<div class="form-container">
    <h1>
        <%= title %>
    </h1>

    <!-- Display flash messages -->
    <% if (messages.notice) { %>
        <p class="notice">
            <%= messages.notice %>
        </p>
        <% } %>

            <!-- Display errors -->
            <% if (errors) { %>
                <ul class="error-list">
                    <% errors.array().forEach(function(error) { %>
                        <li>
                            <%= error.msg %>
                        </li>
                        <% }) %>
                </ul>
                <% } %>

                    <div class="form-section delete-section">
                        <h2>Confirm Delete</h2>

                        <p class="warning">
                            <strong>Warning:</strong> This action cannot be undone.
                            Are you sure you want to delete this vehicle?
                        </p>

                        <div class="vehicle-info-display">
                            <h3>
                                <%= locals.inv_make %>
                                    <%= locals.inv_model %>
                            </h3>
                            <p><strong>Year:</strong>
                                <%= locals.inv_year %>
                            </p>
                            <p><strong>Price:</strong> $<%= new Intl.NumberFormat('en-US').format(locals.inv_price) %>
                            </p>
                            <p><strong>Miles:</strong>
                                <%= new Intl.NumberFormat('en-US').format(locals.inv_miles) %>
                            </p>
                            <p><strong>Color:</strong>
                                <%= locals.inv_color %>
                            </p>
                            <p><strong>Description:</strong>
                                <%= locals.inv_description %>
                            </p>
                        </div>

                        <form action="/inv/delete" method="post">
                            <input type="hidden" name="inv_id" value="<%= locals.inv_id %>">
                            <input type="hidden" name="inv_make" value="<%= locals.inv_make %>">
                            <input type="hidden" name="inv_model" value="<%= locals.inv_model %>">
                            <input type="hidden" name="inv_year" value="<%= locals.inv_year %>">
                            <input type="hidden" name="inv_price" value="<%= locals.inv_price %>">

                            <div class="button-group">
                                <button type="submit" class="btn btn-danger">Delete Vehicle</button>
                                <a href="/inv" class="btn btn-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
</div>