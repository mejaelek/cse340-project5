<div class="form-container">
    <h1>
        <%= title %>
    </h1>

    <!-- Display flash messages -->
    <% if (messages.notice) { %>
        <p class="notice">
            <%= messages.notice %>
        </p>
        <% } %>

            <!-- Display errors -->
            <% if (errors) { %>
                <ul class="error-list">
                    <% errors.array().forEach(function(error) { %>
                        <li>
                            <%= error.msg %>
                        </li>
                        <% }) %>
                </ul>
                <% } %>

                    <div class="form-section">
                        <h2>Add New Vehicle</h2>

                        <form id="addInventoryForm" action="/inv/add-inventory" method="post">

                            <!-- Classification -->
                            <label for="classification_id">Classification:</label>
                            <%- classificationList %>

                                <!-- Make -->
                                <label for="inv_make">Make:</label>
                                <input type="text" id="inv_make" name="inv_make" value="<%= locals.inv_make %>" required
                                    placeholder="e.g., Toyota, Ford, Honda">

                                <!-- Model -->
                                <label for="inv_model">Model:</label>
                                <input type="text" id="inv_model" name="inv_model" value="<%= locals.inv_model %>"
                                    required placeholder="e.g., Camry, F-150, Accord">

                                <!-- Year -->
                                <label for="inv_year">Year:</label>
                                <input type="number" id="inv_year" name="inv_year" value="<%= locals.inv_year %>"
                                    required min="1900" max="<%= new Date().getFullYear() + 1 %>"
                                    placeholder="<%= new Date().getFullYear() %>">

                                <!-- Description -->
                                <label for="inv_description">Description:</label>
                                <textarea id="inv_description" name="inv_description" required rows="5"
                                    placeholder="Enter detailed vehicle description..."><%= locals.inv_description %></textarea>

                                <!-- Image Path -->
                                <label for="inv_image">Image Path:</label>
                                <input type="text" id="inv_image" name="inv_image"
                                    value="<%= locals.inv_image || '/images/vehicles/no-image.png' %>" required
                                    placeholder="/images/vehicles/vehicle-name.jpg">
                                <p class="field-note">Full-size image path</p>

                                <!-- Thumbnail Path -->
                                <label for="inv_thumbnail">Thumbnail Path:</label>
                                <input type="text" id="inv_thumbnail" name="inv_thumbnail"
                                    value="<%= locals.inv_thumbnail || '/images/vehicles/no-image-tn.png' %>" required
                                    placeholder="/images/vehicles/vehicle-name-tn.jpg">
                                <p class="field-note">Thumbnail image path</p>

                                <!-- Price -->
                                <label for="inv_price">Price:</label>
                                <input type="number" id="inv_price" name="inv_price" value="<%= locals.inv_price %>"
                                    required min="0" step="0.01" placeholder="25000.00">

                                <!-- Miles -->
                                <label for="inv_miles">Miles:</label>
                                <input type="number" id="inv_miles" name="inv_miles" value="<%= locals.inv_miles %>"
                                    required min="0" placeholder="50000">

                                <!-- Color -->
                                <label for="inv_color">Color:</label>
                                <input type="text" id="inv_color" name="inv_color" value="<%= locals.inv_color %>"
                                    required placeholder="e.g., Silver, Black, White">

                                <button type="submit" class="submit-btn">Add Vehicle</button>
                        </form>

                        <p class="back-link">
                            <a href="/inv">← Back to Inventory Management</a>
                        </p>
                    </div>
</div>