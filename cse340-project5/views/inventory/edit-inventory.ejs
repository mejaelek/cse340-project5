<%# views/inventory/edit-inventory.ejs %>
    <div class="form-wrapper form-wrapper--wide">
        <h1>
            <%= title %>
        </h1>

        <% if (messages && messages()) { %>
            <div class="flash-messages"><%- messages() %></div>
            <% } %>

                <% if (errors) { %>
                    <div class="error-box">
                        <ul>
                            <% errors.array().forEach(error=> { %>
                                <li>
                                    <%= error.msg %>
                                </li>
                                <% }) %>
                        </ul>
                    </div>
                    <% } %>

                        <form action="/inv/update/" method="post" novalidate>
                            <div class="form-grid">

                                <div class="form-group">
                                    <label for="classification_id">Classification <span
                                            class="required">*</span></label>
                                    <%- classificationList %>
                                </div>

                                <div class="form-group">
                                    <label for="inv_make">Make <span class="required">*</span></label>
                                    <input type="text" id="inv_make" name="inv_make" value="<%= inv_make %>" required
                                        aria-required="true" />
                                </div>

                                <div class="form-group">
                                    <label for="inv_model">Model <span class="required">*</span></label>
                                    <input type="text" id="inv_model" name="inv_model" value="<%= inv_model %>" required
                                        aria-required="true" />
                                </div>

                                <div class="form-group">
                                    <label for="inv_year">Year <span class="required">*</span></label>
                                    <input type="number" id="inv_year" name="inv_year" min="1900"
                                        max="<%= new Date().getFullYear() + 1 %>" value="<%= inv_year %>" required
                                        aria-required="true" />
                                </div>

                                <div class="form-group">
                                    <label for="inv_price">Price ($) <span class="required">*</span></label>
                                    <input type="number" id="inv_price" name="inv_price" min="0" step="0.01"
                                        value="<%= inv_price %>" required aria-required="true" />
                                </div>

                                <div class="form-group">
                                    <label for="inv_miles">Mileage <span class="required">*</span></label>
                                    <input type="number" id="inv_miles" name="inv_miles" min="0"
                                        value="<%= inv_miles %>" required aria-required="true" />
                                </div>

                                <div class="form-group">
                                    <label for="inv_color">Color <span class="required">*</span></label>
                                    <input type="text" id="inv_color" name="inv_color" value="<%= inv_color %>" required
                                        aria-required="true" />
                                </div>

                                <div class="form-group">
                                    <label for="inv_image">Image Path <span class="required">*</span></label>
                                    <input type="text" id="inv_image" name="inv_image" value="<%= inv_image %>" required
                                        aria-required="true" />
                                </div>

                                <div class="form-group">
                                    <label for="inv_thumbnail">Thumbnail Path <span class="required">*</span></label>
                                    <input type="text" id="inv_thumbnail" name="inv_thumbnail"
                                        value="<%= inv_thumbnail %>" required aria-required="true" />
                                </div>

                                <div class="form-group form-group--full">
                                    <label for="inv_description">Description <span class="required">*</span></label>
                                    <textarea id="inv_description" name="inv_description" rows="4" required
                                        aria-required="true"><%= inv_description %></textarea>
                                </div>

                            </div>

                            <%# Hidden field for inv_id — required for update %>
                                <input type="hidden" name="inv_id" value="<%= inv_id %>" />

                                <div class="form-actions">
                                    <input type="submit" value="Update Vehicle" class="btn-submit" />
                                </div>
                        </form>

                        <div class="back-link">
                            <a href="/inv/" title="Return to management">&larr; Back to Management</a>
                        </div>
    </div>