<h2>Submit Feedback</h2>

<% if (errors.length) { %>
    <div class="alert alert-danger">
        <ul>
            <% errors.forEach(e=> { %><li>
                    <%= e %>
                </li>
                <% }) %>
        </ul>
    </div>
    <% } %>

        <form method="POST" action="/courses/<%= course_id %>/feedback">
            <label>Overall rating (1–5)
                <input type="number" name="rating" min="1" max="5" value="<%= old.rating || '' %>" required>
            </label>

            <label>Difficulty
                <select name="difficulty" required>
                    <option value="">Choose…</option>
                    <% ['very_easy','easy','moderate','challenging','very_challenging'].forEach(d=> { %>
                        <option value="<%= d %>" <%=old.difficulty===d?'selected':'' %>><%= d.replace('_',' ') %></option>
      <% }) %>
    </select>
  </label>

  <label>What did you enjoy most?
    <textarea name="enjoyed" minlength="10" maxlength="1000" required><%= old.enjoyed || '' %></textarea>
  </label>

  <label>What could be improved?
    <textarea name="improve" minlength="10" maxlength="1000" required><%= old.improve || '' %></textarea>
  </label>

  <fieldset>
    <legend>Would you recommend this course?</legend>
    <% [' yes','no','maybe'].forEach(r=> { %>
                                <label>
                                    <input type="radio" name="recommend" value="<%= r %>"
                                        <%=old.recommend===r?'checked':'' %> required>
                                    <%= r.charAt(0).toUpperCase()+r.slice(1) %>
                                </label>
                                <% }) %>
                                    </fieldset>

                                    <button type="submit">Submit feedback</button>
        </form>